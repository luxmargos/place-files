{
  "name": "@luxmargos/place-files",
  "version": "0.1.0",
  "description": "Place files from a YAML config into target paths with version checks and backups.",
  "keywords": [
    "file-placement",
    "cli",
    "yaml",
    "backup",
    "config",
    "typescript"
  ],
  "homepage": "https://gitlab.owlfamily.net/tooling/file-hydrator#readme",
  "bugs": {
    "url": "https://gitlab.owlfamily.net/tooling/file-hydrator/-/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://gitlab.owlfamily.net/tooling/file-hydrator.git"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "place-files": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "examples/README.md",
    "examples/simple",
    "examples/basic",
    "examples/testbed/README.md",
    "examples/testbed/place-files.yml",
    "examples/testbed/source"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js",
    "print:help": "node dist/cli.js --help",
    "test": "npm run build && node scripts/test-init.mjs && node scripts/test-version-up.mjs",
    "test:init": "npm run build && node scripts/test-init.mjs",
    "test:version-up": "npm run build && node scripts/test-version-up.mjs",
    "testbed:reset": "node scripts/reset-testbed.mjs",
    "testbed:dry-run": "node dist/cli.js --config examples/testbed/place-files.yml --dry-run --verbose",
    "testbed:run": "node dist/cli.js --config examples/testbed/place-files.yml --verbose",
    "testbed:force": "node dist/cli.js --config examples/testbed/place-files.yml --force --verbose",
    "prepare": "npm run build"
  },
  "dependencies": {
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.20.0",
    "typescript": "^5.9.0"
  },
  "engines": {
    "node": ">=22.17.0"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  }
}
